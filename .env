# Telegram Bot Configuration
BOT_TOKEN=your_telegram_bot_token_here

# GitHub Configuration
GITHUB_TOKEN=ghp_YOUR_GITHUB_TOKEN_HERE
CONFIG_REPO=YOUR_USERNAME/vless-configs
PAGES_REPO=YOUR_USERNAME/vless-configs

# VLESS Server Configuration
VLESS_ADDRESS=your-domain.com
VLESS_PORT=443
VLESS_PATH=/vless
VLESS_SNI=your-domain.com

# Optional: Advanced VLESS Parameters
# VLESS_ALPN=h2,http/1.1
# VLESS_FP=chrome
